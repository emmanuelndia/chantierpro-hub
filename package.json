{
  "name": "chantierpro-hub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "npm run clean && next dev",
    "clean": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"if (Test-Path .next) { Remove-Item -LiteralPath .next -Recurse -Force }\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:seed": "prisma db seed",
    "db:seed-ivorycoast": "tsx prisma/seed-ivory-coast.ts",
    "db:reset-seed": "prisma db push --force-reset && npm run db:seed-ivorycoast",
    "test:auth-smoke": "tsx scripts/auth-smoke.ts",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push"
  },
  "dependencies": {
    "@prisma/client": "^6.7.0",
    "@supabase/supabase-js": "^2.57.4",
    "@tanstack/react-query": "^5.100.6",
    "bcrypt": "^6.0.0",
    "exceljs": "^4.4.0",
    "jose": "^6.2.2",
    "jspdf": "^2.5.2",
    "lucide-react": "^0.462.0",
    "next": "^15.0.0",
    "next-pwa": "^5.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.0.0",
    "eslint-config-prettier": "^10.1.2",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "prisma": "^6.7.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}
